# ---------------------------------------------------------------------------
# Secrets & local config  — NEVER commit real credentials.
# The *.example files ARE committed (they hold no secrets); real ones are not.
# ---------------------------------------------------------------------------
# Python builds: .env (auto-loaded by the scripts)
.env
.env.*
!.env.example
# PHP build: config.php (auto-loaded by swiftseek_connect)
config.php
**/config.php
!config.example.php

# ---------------------------------------------------------------------------
# swiftseek-lite data store (the single-file JSON corpus + its atomic temp file)
# ---------------------------------------------------------------------------
swiftseek.json
swiftseek.json.tmp
*.swiftseek.json

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# ---------------------------------------------------------------------------
# PHP
# ---------------------------------------------------------------------------
vendor/
composer.lock

# ---------------------------------------------------------------------------
# Editors / OS cruft
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
