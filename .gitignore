# ---------------------------------------------------------------------------
# Secrets & local config  — NEVER commit real credentials.
# .env.example files ARE committed (they hold no secrets); real .env files are not.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# swiftseek-lite data store (the single-file JSON corpus + its atomic temp file)
# ---------------------------------------------------------------------------
swiftseek.json
swiftseek.json.tmp
*.swiftseek.json

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# ---------------------------------------------------------------------------
# PHP
# ---------------------------------------------------------------------------
vendor/
composer.lock

# ---------------------------------------------------------------------------
# Editors / OS cruft
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
