# swiftseek-mysql configuration.
# Copy this file to ".env" in the same folder and edit. It is auto-loaded at startup.
# Real environment variables ALWAYS take precedence over this file.
# (Override the search path with SWIFTSEEK_ENV=/path/to/your.env if you like.)
#
# NEVER commit your real .env — the repo .gitignore already excludes it.
# Use a DB user scoped to just the `documents` table; this tool only SELECT/INSERTs.

SWIFTSEEK_HOST=localhost
SWIFTSEEK_PORT=3306
SWIFTSEEK_USER=app
SWIFTSEEK_PASSWORD=change-me
SWIFTSEEK_DB=docs
